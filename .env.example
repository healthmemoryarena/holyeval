# =============================================================
# HolyEval Configuration
# Copy this file to .env and fill in your values
# =============================================================

# LLM API Keys (at least one required)
OPENAI_API_KEY=sk-xxx
GOOGLE_API_KEY=xxx

# OpenRouter (optional — unified multi-provider access)
# OPENROUTER_API_KEY=sk-or-xxx

# Web UI port (optional, default: 8000)
# HOLYEVAL_PORT=8000
